# Local development defaults (docker-compose already sets these for the container)
DATABASE_URL=postgresql+psycopg://mavva:mavva@localhost:5433/mavva
SECRET_KEY=dev-secret-change-in-production
ENVIRONMENT=development
FRONTEND_ORIGIN=http://localhost:5173

# Production only
# RESEND_API_KEY=re_xxx
# EMAIL_FROM=Mavva <noreply@mavva.app>

# Admin content write-back (production): fine-grained PAT with contents:write
# on the repo below. Without it, "Publicar" writes to content/ on disk (dev).
# GITHUB_TOKEN=github_pat_xxx
# GITHUB_REPO=silvasamuel/mavva
# GITHUB_BRANCH=main
