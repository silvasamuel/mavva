{
    "$schema": "https://openapi.vercel.sh/vercel.json",
    "services": {
        "frontend": {
            "root": "frontend",
            "framework": "vite"
        },
        "backend": {
            "root": "backend",
            "entrypoint": "app.main:app",
            "buildCommand": "sh scripts/vercel_build.sh"
        }
    },
    "rewrites": [
        {
            "source": "/api(/.*)?",
            "destination": {
                "service": "backend"
            }
        },
        {
            "source": "/(.*)",
            "destination": {
                "service": "frontend"
            }
        }
    ]
}
